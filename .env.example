# X Developer Console credentials (https://console.x.com)
CLIENT_ID=your_client_id
CLIENT_SECRET=your_client_secret
REDIRECT_URI=http://127.0.0.1:8080/callback

# API base URL (default: production — leave commented for real X API)
# API_BASE_URL=https://api.x.com
# API_BASE_URL=http://127.0.0.1:8080   # only when running: playground start

# xAI / Grok (for drafts fetch — separate from X API credits)
XAI_API_KEY=your_xai_api_key
XAI_MODEL=grok-3-mini

# Max posts per category per UTC day when publishing approved drafts
DRAFTS_DAILY_CAP=3
